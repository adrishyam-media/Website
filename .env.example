# Copy this file to .env.local and fill in the values

# Your site's public URL (used for sitemap and robots.txt)
NEXT_PUBLIC_SITE_URL=https://adrishyam.media

# Resend API key for contact form emails
# Get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_RECIPIENT_EMAIL=hello@adrishyam.media

# Sender address shown on emails (must be a verified Resend domain)
# Leave unset to use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=hello@adrishyam.media
